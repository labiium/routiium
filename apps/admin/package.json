{
  "name": "routiium-admin",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "build": "npm run typecheck && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepack": "npm run build",
    "prepublishOnly": "npm run lint && npm run build && npm audit --audit-level=high"
  },
  "dependencies": {
    "lucide-react": "^0.576.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2"
  },
  "description": "Static Routiium admin panel for managing keys, routing, limits, analytics, prompts, MCP, and runtime state.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/labiium/routiium#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/labiium/routiium.git",
    "directory": "apps/admin"
  },
  "bugs": {
    "url": "https://github.com/labiium/routiium/issues"
  },
  "keywords": [
    "routiium",
    "llm",
    "admin",
    "gateway",
    "openai",
    "router",
    "dashboard"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10"
  }
}
