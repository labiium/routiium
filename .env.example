# Routiium — Example .env
# Copy this file to `.env` and adjust values for your environment.
# All values are optional unless noted. Lines starting with `#` are comments.

###############################################################################
# Server
###############################################################################

# Address the HTTP server binds to (host:port).
BIND_ADDR=0.0.0.0:8088

# Logging (tracing) configuration.
# Example levels: error,warn,info,debug,trace
RUST_LOG=info,tower_http=info


###############################################################################
# Admin and privileged runtime surfaces
###############################################################################

# REQUIRED for admin endpoints. Without this, admin APIs fail closed.
ROUTIIUM_ADMIN_TOKEN=change-me-admin-token

# Only for throwaway local development; never enable in production.
# ROUTIIUM_INSECURE_ADMIN=0

# MCP config updates can spawn local commands through configured MCP servers, so
# runtime MCP config writes are disabled unless explicitly enabled.
# ROUTIIUM_ALLOW_MCP_CONFIG_UPDATE=0

# /convert is safe by default and does not merge internal prompts/MCP metadata.
# Add ?include_internal_config=true with admin auth to inspect the full internal conversion.
# ROUTIIUM_PUBLIC_CONVERT_INTERNAL_CONFIG=0

###############################################################################
# Upstream (OpenAI or compatible)
###############################################################################

# REQUIRED for /proxy to contact a real upstream.
# Do NOT commit real keys; use placeholders locally.
# OPENAI_API_KEY=sk-your-key

# Base URL for upstream API.
# Default (if unset): https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Upstream mode:
# - responses (default): forward to /responses (Responses API)
# - chat or chat-completions: rewrite upstream path to /chat/completions and
#   adapt payload for Chat Completions.
UPSTREAM_MODE=responses
# Alias of UPSTREAM_MODE (either can be used; UPSTREAM_MODE takes precedence).
# ROUTIIUM_UPSTREAM=responses

# Default models used by integration tests / clients (optional).
# MODEL=gpt-4.1-nano
# CHAT_MODEL=gpt-4.1-nano

# Built-in router + judge defaults. Leave enabled for safe-by-default routing.
ROUTIIUM_ROUTER_MODE=embedded
ROUTIIUM_ROUTER_STRICT=1
ROUTIIUM_ROUTER_PRIVACY_MODE=full
ROUTIIUM_JUDGE_MODE=protect
ROUTIIUM_RESPONSE_GUARD=protect
ROUTIIUM_STREAMING_SAFETY=chunk
ROUTIIUM_JUDGE_LLM=auto
ROUTIIUM_JUDGE_SENSITIVE_TARGET=secure
ROUTIIUM_JUDGE_ON_DENY=block
ROUTIIUM_REJECTION_MODE=agent_result
ROUTIIUM_WEB_JUDGE=restricted
# Optional custom judge policy/prompt overlay. Generate with:
# routiium judge policy init --out config/judge-policy.json
# ROUTIIUM_JUDGE_POLICY_PATH=./config/judge-policy.json
# Optional durable safety audit log for router denials and response-guard blocks.
# ROUTIIUM_SAFETY_AUDIT_PATH=./data/safety-audit.jsonl
# ROUTIIUM_SAFETY_AUDIT_MAX_EVENTS=1000

# Set ROUTIIUM_ROUTER_MODE=off only if you explicitly want legacy routing.

# Some upstreams require a top-level "input" string for non-streaming calls.
# When truthy (1,true,yes,on), derive and inject a best-effort "input".
ROUTIIUM_UPSTREAM_INPUT=0

###############################################################################
# CORS (Cross-Origin Resource Sharing)
# Defaults are same-origin only when unset. Set explicit values for browser clients.
###############################################################################

# Allowed origins:
# - Comma-separated list: "https://a.example.com, https://b.example.com"
# - "*" allows any origin; prefer CORS_ALLOW_ALL=1 for explicit local-only opt-in
# CORS_ALLOWED_ORIGINS=https://yourapp.example.com
# CORS_ALLOW_ALL=0

# Allowed HTTP methods. Unset means Actix default behavior; set for browsers.
# CORS_ALLOWED_METHODS=GET,POST,OPTIONS

# Allowed request headers. Unset means Actix default behavior; set for browsers.
# CORS_ALLOWED_HEADERS=content-type,authorization

# Allow credentials (cookies, auth headers) — enable cautiously:
# truthy values: 1,true,yes,on
# CORS_ALLOW_CREDENTIALS=0

# Preflight max-age in seconds (browser caches OPTIONS response).
# CORS_MAX_AGE=600

###############################################################################
# Production CORS example (uncomment and customize)
###############################################################################
# CORS_ALLOWED_ORIGINS=https://yourapp.example.com
# CORS_ALLOWED_METHODS=GET,POST,OPTIONS
# CORS_ALLOWED_HEADERS=content-type,authorization
# CORS_ALLOW_CREDENTIALS=1
# # CORS_MAX_AGE=600
